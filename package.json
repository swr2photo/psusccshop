{
  "name": "psuscc-shop",
  "version": "2.1.0",
  "private": true,
  "workspaces": [
    "server"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:api": "bun run --cwd server dev",
    "start:api": "bun run --cwd server start",
    "generate:api-registry": "node server/scripts/generate-registry.mjs",
    "dev:all": "npx concurrently -k \"npm run dev\" \"npm run dev:api\"",
    "build": "next build",
    "build:cloudflare": "NODE_OPTIONS=--max-old-space-size=6144 opennextjs-cloudflare build",
    "deploy:cloudflare": "NODE_OPTIONS=--max-old-space-size=6144 opennextjs-cloudflare build && wrangler deploy",
    "start": "next start",
    "lint": "eslint",
    "migrate:images": "npx tsx scripts/migrate-image-urls.ts",
    "cron": "tsx scripts/cron-worker.ts",
    "cron:dev": "tsx watch scripts/cron-worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/material-nextjs": "^9.1.0",
    "@sentry/nextjs": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/three": "^0.184.1",
    "@upstash/redis": "^1.38.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "firebase-admin": "^13.6.1",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.7",
    "next-auth": "^4.24.13",
    "node-cron": "^4.2.1",
    "pg": "^8.19.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "web-push": "^3.6.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.99.0"
  },
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all",
    "iOS >= 16.4",
    "Safari >= 16.4"
  ]
}
